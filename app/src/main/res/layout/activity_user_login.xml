<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    android:scrollbars="none"
    android:padding="20dp"
    tools:context=".Common.UserLogInSignUp.UserLogin">

    <ImageView android:padding="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_back"/>

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:id="@+id/logo"
        android:transitionName="logo_image"
        android:layout_gravity="center"
        android:src="@drawable/pulse"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="40sp"
        android:fontFamily="@font/muli_black"
        android:textAlignment="center"
        android:layout_gravity="center"
        android:textColor="@color/black"
        android:transitionName="logo_text"
        android:text="HELLO THERE,\nWELCOME BACK"/>

    <TextView
        android:transitionName="sloganText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textAlignment="center"
        android:fontFamily="@font/antic"
        android:text="Sign In to continue"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:transitionName="username_tran"
            android:hint="@string/username"
            android:layout_height="wrap_content"
            android:id="@+id/username"
            app:startIconDrawable="@drawable/ic_edit"
            app:startIconTint="@color/black"
            app:hintTextColor="@color/black"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:hint="@string/password"
            app:hintTextColor="@color/black"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/black"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            android:id="@+id/password"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:inputType="textPassword"
                android:transitionName="password_tran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </com.google.android.material.textfield.TextInputLayout>


        <Button
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:layout_gravity="right"
            android:elevation="0dp"
            android:textColor="@color/black_overlay"
            android:text="@string/forget_password"/>


        <Button android:id="@+id/login_btn"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:transitionName="button_tran"
            android:text="@string/log_in"/>

        <Button android:id="@+id/callSignUp"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:layout_gravity="center"
            android:elevation="0dp"
            android:onClick="callUserSignUp"
            android:transitionName="button_tran2"
            android:textColor="@color/black_overlay"
            android:text="@string/new_user"
            android:textAllCaps="true"/>


    </LinearLayout>

</LinearLayout>