<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="2dp"
    app:cardElevation="8dp">

    <RelativeLayout
        android:padding="5dp"
        android:layout_width="350dp"
        android:layout_height="100dp">

        <ImageView android:id="@+id/mv_image"
            android:layout_marginLeft="10dp"
            android:layout_width="80dp"
            android:layout_centerVertical="true"
            android:layout_height="80dp"
            android:src="@drawable/card_1"
            android:scaleType="centerCrop"/>

        <TextView android:id="@+id/mv_title"
            android:text="Macdonald's"
            android:layout_toRightOf="@id/mv_image"
            android:textColor="@color/black"
            android:layout_marginLeft="20dp"
            android:textSize="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView android:id="@+id/mv_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:textAlignment="center"
            android:text="uouoeiruteroitu"
            android:layout_below="@id/mv_title"
            android:layout_toRightOf="@id/mv_image"
            android:padding="10dp"/>

        <RatingBar android:id="@+id/mv_rating"
            style="@style/Widget.AppCompat.RatingBar.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/mv_description"
            android:layout_marginLeft="20dp"
            android:layout_toRightOf="@id/mv_image"
            android:progressTint="@color/black"
            android:rating="2.3" />

        <Button
            android:layout_marginLeft="30dp"
            android:layout_centerVertical="true"
            android:layout_toRightOf="@id/mv_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="book"/>

    </RelativeLayout>


</androidx.cardview.widget.CardView>