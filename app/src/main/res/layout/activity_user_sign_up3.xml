<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="20dp"
    android:orientation="vertical"
    tools:context=".Common.UserLogInSignUp.UserSignUp3">


    <ProgressBar
        android:id="@+id/progress_pg1"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:progressTint="@color/signature_blue"
        android:progress="60"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pg_3"
        android:layout_marginBottom="150dp"
        android:layout_marginTop="5dp"
        android:layout_gravity="center"
        android:textColor="@color/black"/>


    <TextView
        android:layout_width="wrap_content"
        android:layout_gravity="center"
        android:layout_height="wrap_content"
        android:text="@string/gender"
        android:textColor="@color/black"
        android:textSize="18sp"/>

    <LinearLayout android:orientation="vertical"
        android:background="@drawable/blue_border"
        android:layout_width="match_parent"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="80dp"
        android:layout_height="wrap_content">

       <RadioGroup
           android:theme="@style/Theme.BluePill.Custom"
           android:id="@+id/radio_group"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:gravity="center"
           android:layout_gravity="center"
           android:orientation="horizontal">

           <RadioButton
               android:padding="20dp"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:id="@+id/male"
               android:text="Male"/>

           <RadioButton
               android:padding="20dp"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:id="@+id/female"
               android:text="Female"/>

           <RadioButton
               android:padding="20dp"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:id="@+id/other"
               android:text="Other"/>

       </RadioGroup>

    </LinearLayout>

    <Button
        android:layout_width="200dp"
        android:elevation="1dp"
        android:onClick="callPage4"
        android:layout_marginTop="60dp"
        android:layout_gravity="center"
        android:transitionName="button_tran"
        android:layout_height="60dp"
        android:text="@string/next"/>



</LinearLayout>